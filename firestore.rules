rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ------------------------------------------------------------------------
    // Helper Functions
    // ------------------------------------------------------------------------
    function isAuthenticated() {
      return request.auth != null;
    }

    function isEventOrganizer(eventId) {
      let event = get(/databases/$(database)/documents/events/$(eventId));
      return isAuthenticated() && event.data.organizerId == request.auth.uid;
    }

    function isEventAttendee(eventId) {
      let attendee = get(/databases/$(database)/documents/events/$(eventId)/attendees/$(request.auth.uid));
      return attendee.exists;
    }

    // ------------------------------------------------------------------------
    // /users Collection (Organizer Profiles)
    // ------------------------------------------------------------------------
    match /users/{userId} {
      // Anyone can create a profile upon signup
      allow create: if isAuthenticated() && request.auth.uid == userId;
      // Users can only read/update their own profile
      allow read, update: if isAuthenticated() && request.auth.uid == userId;
      allow delete: if false; // Soft deletes handled by a function later if needed
    }

    // ------------------------------------------------------------------------
    // /events Collection
    // ------------------------------------------------------------------------
    match /events/{eventId} {
      // Any authenticated organizer can create an event
      allow create: if isAuthenticated() && request.resource.data.organizerId == request.auth.uid;

      // Anyone can read events (to validate join codes, view public event info)
      allow read: if true;

      // Only the event creator can update/delete it, OR attendees joining
      // (When an attendee joins, the app increments attendeeCount, so we must allow that specific update)
      allow update: if isEventOrganizer(eventId) ||
                    (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['attendeeCount', 'photoCount', 'storageBytes', 'totalSize']));

      allow delete: if isEventOrganizer(eventId);
    }

    // ------------------------------------------------------------------------
    // /events/{eventId}/attendees Subcollection
    // ------------------------------------------------------------------------
    match /events/{eventId}/attendees/{attendeeId} {
      // Attendees can create their own attendee record when uploading first photo
      allow create: if isAuthenticated() && request.auth.uid == attendeeId;

      // Anyone can read attendee lists for an event
      allow read: if true;

      // Attendees can update their own record (e.g., photo count)
      allow update: if isAuthenticated() && request.auth.uid == attendeeId;

      // Only organizers can delete attendee records
      allow delete: if isEventOrganizer(eventId);
    }

    // ------------------------------------------------------------------------
    // /events/{eventId}/photos Subcollection
    // ------------------------------------------------------------------------
    match /events/{eventId}/photos/{photoId} {
      // Authenticated users can create photos for events they're attending
      allow create: if isAuthenticated() && isEventAttendee(eventId);

      // Anyone can view photos for any event
      allow read: if true;

      // Only the photo uploader can update their photos
      // Organizers can also update photos (for moderation)
      allow update: if (isAuthenticated() && resource.data.uploadedBy == request.auth.uid) ||
                     isEventOrganizer(eventId);

      // Only photo uploader or event organizer can delete photos
      allow delete: if (isAuthenticated() && resource.data.uploadedBy == request.auth.uid) ||
                    isEventOrganizer(eventId);
    }

    // ------------------------------------------------------------------------
    // /event_members Collection (Named Attendees)
    // ------------------------------------------------------------------------
    match /event_members/{memberId} {
      // Anyone can join an event (creates a named attendee record)
      allow create: if true;

      // Anyone can read member lists (to show "Who's here")
      allow read: if true;

      // Organizers can soft-delete members
      allow update: if isEventOrganizer(resource.data.eventId);

      allow delete: if isEventOrganizer(resource.data.eventId);
    }
  }
}
